---
interface Props {
  allTags?: string[];
}
const { allTags = ['AI & ML', 'Data Science', 'DevOps', 'Distributed Systems', 'Robotics', 'Web Development']} = Astro.props;
---

<div class="filter-sort-section">
  <!-- Search Bar -->
  <div class="search-bar">
    <label for="search-input" class="sr-only">Search projects</label>
    <input
      type="text"
      id="search-input"
      placeholder="Search by name, description or tag..."
      class="input"
    />
  </div>

  <div class="filters">
    <!-- Tag Filter Dropdown (Multi-select) -->
    <div class="custom-dropdown" id="tag-dropdown">
      <button class="dropdown-trigger" aria-haspopup="true" aria-expanded="false" aria-controls="tag-menu">
        <span class="trigger-label">Tags</span>
        <span class="filter-count" id="tag-count"></span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="dropdown-icon" aria-hidden="true">
          <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      </button>
      <div class="dropdown-menu" id="tag-menu" role="menu">
        <div class="menu-items" role="none">
          {allTags.map(tag => (
            <button class="menu-item tag-item" data-tag={tag} role="menuitemcheckbox" aria-checked="false">
              <span class="checkbox" aria-hidden="true"></span>
              {tag}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Sort Option Dropdown -->
    <div class="custom-dropdown" id="sort-dropdown">
      <button class="dropdown-trigger" aria-haspopup="true" aria-expanded="false" aria-controls="sort-menu">
        <span class="trigger-label" id="sort-label">Sort</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="dropdown-icon" aria-hidden="true">
          <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      </button>
      <div class="dropdown-menu" id="sort-menu" role="menu">
        <div class="menu-items" role="none">
          <button class="menu-item sort-item active" data-sort="date-desc" role="menuitemradio" aria-checked="true">Newest</button>
          <button class="menu-item sort-item" data-sort="date-asc" role="menuitemradio" aria-checked="false">Oldest</button>
          <button class="menu-item sort-item" data-sort="name-asc" role="menuitemradio" aria-checked="false">Name (A-Z)</button>
          <button class="menu-item sort-item" data-sort="name-desc" role="menuitemradio" aria-checked="false">Name (Z-A)</button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .filter-sort-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
    justify-content: space-between;
    align-items: center;
  }

  @media (min-width: 640px) {
    .filter-sort-section {
      flex-direction: row;
      margin-bottom: 2rem;
    }
    .search-bar {
      width: 40%;
      min-width: 280px;
    }
    .filters {
      flex-direction: row;
      justify-content: flex-end;
    }
  }

  .search-bar {
    width: 100%;
  }

  .filters {
    display: flex;
    gap: 1rem;
    width: 100%;
    align-items: center;
  }

  .input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--gray-800);
    border-radius: 0.75rem;
    background-color: var(--gray-999);
    color: var(--gray-200);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    transition: border-color var(--theme-transition), box-shadow var(--theme-transition);
  }

  .input:focus {
    outline: none;
    border-color: var(--accent-regular);
    box-shadow: 0 0 0 1px var(--accent-regular);
  }

  :global(.theme-dark) .input {
    border-color: var(--gray-700);
  }

  /* Custom Dropdown Styles */
  .custom-dropdown {
    position: relative;
    display: inline-block;
  }

  .dropdown-trigger {
    background: var(--gray-999);
    border: none;
    color: var(--gray-300);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: color var(--theme-transition);
  }

  .dropdown-trigger:hover {
    color: var(--gray-100);
  }

  .dropdown-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--gray-600);
    transition: color var(--theme-transition);
  }

  .dropdown-trigger:hover .dropdown-icon {
    color: var(--gray-400);
  }

  .filter-count {
    font-weight: 600;
    color: var(--accent-regular);
    margin-left: 0.125rem;
  }

  .dropdown-menu {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    width: 12rem;
    background-color: var(--gray-999);
    border-radius: 0.5rem;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--gray-800);
    z-index: 50;
  }

  :global(.theme-dark) .dropdown-menu {
    border-color: var(--gray-700);
  }

  .custom-dropdown.open .dropdown-menu {
    display: block;
    animation: dropdownFadeIn 0.1s ease-out;
  }

  @keyframes dropdownFadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  .menu-items {
    padding: 0.25rem 0;
  }

  .menu-item {
    width: 100%;
    text-align: left;
    padding: 0.5rem 1rem;
    background: none;
    border: none;
    font-size: var(--text-sm);
    color: var(--gray-300);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: var(--theme-transition), color var(--theme-transition);
  }

  .menu-item:hover, .menu-item:focus {
    background-color: var(--gray-800);
    color: var(--gray-100);
    outline: none;
  }

  :global(.theme-dark) .menu-item:hover {
    background-color: var(--gray-700);
  }

  .menu-item.active {
    font-weight: 600;
    color: var(--gray-100);
  }

  /* Multi-select Checkbox look */
  .checkbox {
    width: 1rem;
    height: 1rem;
    border: 1px solid var(--gray-600);
    border-radius: 0.25rem;
    position: relative;
    flex-shrink: 0;
  }

  .menu-item.active .checkbox {
    background-color: var(--accent-regular);
    border-color: var(--accent-regular);
  }

  .menu-item.active .checkbox::after {
    content: '';
    position: absolute;
    left: 0.3rem;
    top: 0.1rem;
    width: 0.3rem;
    height: 0.5rem;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  @media (max-width: 639px) {
    .custom-dropdown {
      display: block;
      align-self: flex-start;
    }

    .dropdown-menu {
      position: static;
      box-shadow: none;
      left: 0;
      overflow: auto;
    }
  }
</style>
