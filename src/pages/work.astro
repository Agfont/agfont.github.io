---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import WorkCard from '../components/WorkCard.astro';
import FilterBar from '../components/FilterBar.astro';

const allWork = await getCollection('work');
const sortedWork = allWork.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout>
  <main class="container">
    <h1 class="heading">Some of my best work</h1>
    <work-filter data-work={JSON.stringify(sortedWork)}>
      <FilterBar />
      <div id="work-items-grid" class="work-grid">
        {sortedWork.map((project) => <WorkCard project={project} />)}
      </div>
    </work-filter>
  </main>
</Layout>

<script>
  class WorkFilter extends HTMLElement {
    connectedCallback() {
      const items = JSON.parse(this.dataset.work || '[]') as { id: string; data: { title: string; description: string; tags: string[]; date: string } }[];
      const grid = this.querySelector('#work-items-grid') as HTMLElement;
      const input = this.querySelector('#search-input') as HTMLInputElement;
      const cards = Array.from(this.querySelectorAll('.work-card')) as HTMLElement[];
      const cardMap = new Map(cards.map(c => [c.dataset.id, c]));
      const tagCount = this.querySelector('#tag-count') as HTMLElement;
      const sortLabel = this.querySelector('#sort-label') as HTMLElement;

      const params = new URLSearchParams(window.location.search);
      let tags = params.get('tags')?.split(',').filter(Boolean) || [];
      let sort = params.get('sort') || 'date-desc';
      input.value = params.get('search') || '';

      const update = () => {
        const p = new URLSearchParams();
        if (tags.length) p.set('tags', tags.join(','));
        if (sort !== 'date-desc') p.set('sort', sort);
        if (input.value) p.set('search', input.value);
        
        const search = p.toString();
        const newUrl = search ? `?${search}${location.hash}` : location.pathname + location.hash;
        window.history.replaceState({}, '', newUrl);

        // Sync UI state
        this.querySelectorAll('.tag-item').forEach(el => el.classList.toggle('active', tags.includes((el as HTMLElement).dataset.tag!)));
        if (tagCount) tagCount.textContent = tags.length ? `(${tags.length})` : '';
        this.querySelectorAll('.sort-item').forEach(el => {
          const active = (el as HTMLElement).dataset.sort === sort;
          el.classList.toggle('active', active);
          if (active && sortLabel) sortLabel.textContent = el.textContent;
        });

        // Filter and Sort
        const searchStr = input.value.toLowerCase();
        const filtered = items
          .filter(i => (!searchStr || [i.data.title, i.data.description, ...i.data.tags].some(s => s.toLowerCase().includes(searchStr))) && (!tags.length || tags.some(t => i.data.tags.includes(t))))
          .sort((a, b) => {
            const da = new Date(a.data.date).getTime(), db = new Date(b.data.date).getTime();
            if (sort === 'date-desc') return db - da;
            if (sort === 'date-asc') return da - db;
            return sort === 'name-asc' ? a.data.title.localeCompare(b.data.title) : b.data.title.localeCompare(a.data.title);
          });

        // Render reordered grid
        const ids = new Set(filtered.map(i => i.id));
        cards.forEach(c => (c.style.display = ids.has(c.dataset.id!) ? '' : 'none'));
        filtered.forEach(i => grid?.appendChild(cardMap.get(i.id)!));
      };

      this.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const trigger = target.closest('.dropdown-trigger');
        const tagItem = target.closest('.tag-item') as HTMLElement;
        const sortItem = target.closest('.sort-item') as HTMLElement;

        if (trigger) {
          const isOpen = trigger.parentElement!.classList.contains('open');
          this.querySelectorAll('.custom-dropdown').forEach(d => d.classList.remove('open'));
          trigger.parentElement!.classList.toggle('open', !isOpen);
          e.stopPropagation();
        } else {
          this.querySelectorAll('.custom-dropdown').forEach(d => d.classList.remove('open'));
        }

        if (tagItem) {
          const t = tagItem.dataset.tag!;
          tags = tags.includes(t) ? tags.filter(x => x !== t) : [...tags, t];
          update();
          e.stopPropagation();
        }

        if (sortItem) {
          sort = sortItem.dataset.sort!;
          update();
        }
      });

      input.addEventListener('input', update);
      update();
    }
  }
  customElements.define('work-filter', WorkFilter);
</script>

<style>
  .container {
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
    padding: 0.5rem 1rem 1rem 1rem;
  }
  .heading {
    font-size: var(--text-xl);
    margin-bottom: 2rem;
    font-weight: 600;
    text-align: center;
    color: var(--gray-0);
  }
  .work-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .work-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2.5rem;
    }
    .heading { font-size: var(--text-2xl); margin-bottom: 3rem; }
    .container { padding: 1rem 1rem; }
  }
  @media (min-width: 1024px) {
    .work-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
</style>