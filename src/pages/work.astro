---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import WorkCard from '../components/WorkCard.astro';
import MainHead from '../components/MainHead.astro';
import FilterBar from '../components/FilterBar.astro';

const allWork = await getCollection('work');

// Sort by date in descending order (newest first)
const sortedWork = allWork.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

---

<Layout>
  <MainHead />
  <main class="container">
    <h1 class="heading">Some of my best work</h1>

    <FilterBar />

    <!-- Work Items Grid -->
    <div id="work-items-grid" class="work-grid">
      {sortedWork.map((project) => (
        <WorkCard project={project} />
      ))}
    </div>
  </main>
</Layout>

<script is:inline define:vars={{ allWork }}>
  const workItems = allWork;
  const grid = document.getElementById('work-items-grid');
  const searchInput = document.getElementById('search-input');
  // Cache existing DOM cards so we can show/hide and reorder without re-rendering
  const cards = Array.from(grid.querySelectorAll('.work-card'));
  const cardMap = new Map(cards.map(c => [c.dataset.id, c]));
  
  // Custom Dropdown State
  let selectedTags = [];
  let currentSort = 'date-desc';

  // UI Elements
  const tagDropdown = document.getElementById('tag-dropdown');
  const sortDropdown = document.getElementById('sort-dropdown');
  const tagCountDisplay = document.getElementById('tag-count');
  const sortLabel = document.getElementById('sort-label');

  // Toggle Dropdowns
  function closeAllDropdowns() {
    document.querySelectorAll('.custom-dropdown').forEach(d => {
      d.classList.remove('open');
      d.querySelector('.dropdown-trigger').setAttribute('aria-expanded', 'false');
    });
  }

  document.querySelectorAll('.dropdown-trigger').forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const parent = trigger.parentElement;
      const isOpen = parent.classList.contains('open');
      closeAllDropdowns();
      if (!isOpen) {
        parent.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });

  document.addEventListener('click', closeAllDropdowns);

  // Handle Tag Selection (Multi-select)
  document.querySelectorAll('.tag-item').forEach(item => {
    item.addEventListener('click', (e) => {
      e.stopPropagation();
      const tag = item.dataset.tag;
      if (selectedTags.includes(tag)) {
        selectedTags = selectedTags.filter(t => t !== tag);
        item.classList.remove('active');
      } else {
        selectedTags.push(tag);
        item.classList.add('active');
      }
      
      // Update count display
      tagCountDisplay.textContent = selectedTags.length > 0 ? `(${selectedTags.length})` : '';
      filterAndSortWork();
    });
  });

  // Handle Sort Selection (Single-select)
  document.querySelectorAll('.sort-item').forEach(item => {
    item.addEventListener('click', (e) => {
      const sort = item.dataset.sort;
      currentSort = sort;
      
      // Update UI
      document.querySelectorAll('.sort-item').forEach(i => i.classList.remove('active'));
      item.classList.add('active');
      sortLabel.textContent = item.textContent;
      
      closeAllDropdowns();
      filterAndSortWork();
    });
  });

  function renderWorkItems(items) {
    const order = items.map(i => i.id);
    const idSet = new Set(order);

    // Show/hide existing cards and set aria-hidden
    cards.forEach(card => {
      const id = card.dataset.id;
      const shouldShow = idSet.has(id);
      card.style.display = shouldShow ? '' : 'none';
      card.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
    });

    // Reorder visible cards to match filtered order (appendChild moves existing nodes)
    order.forEach(id => {
      const card = cardMap.get(id);
      if (card) grid.appendChild(card);
    });

    // If focus was inside a now-hidden card, move focus to the search input
    const activeCard = document.activeElement && document.activeElement.closest && document.activeElement.closest('.work-card');
    if (activeCard && activeCard.getAttribute('aria-hidden') === 'true') {
      searchInput.focus();
    }
  }

  function filterAndSortWork() {
    let filtered = [...workItems];

    // Filter by search input
    const searchTerm = searchInput.value.toLowerCase();
    if (searchTerm) {
      filtered = filtered.filter(item =>
        item.data.title.toLowerCase().includes(searchTerm) ||
        item.data.description.toLowerCase().includes(searchTerm) ||
        item.data.tags.some(tag => tag.toLowerCase().includes(searchTerm))
      );
    }

    // Filter by tag (Multi-select)
    if (selectedTags.length > 0) {
      filtered = filtered.filter(item => 
        selectedTags.some(tag => item.data.tags.includes(tag))
      );
    }

    // Sort
    filtered.sort((a, b) => {
      if (currentSort === 'date-desc') {
        return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
      } else if (currentSort === 'date-asc') {
        return new Date(a.data.date).getTime() - new Date(b.data.date).getTime();
      } else if (currentSort === 'name-asc') {
        return a.data.title.localeCompare(b.data.title);
      } else if (currentSort === 'name-desc') {
        return b.data.title.localeCompare(a.data.title);
      }
      return 0;
    });

    renderWorkItems(filtered);
  }

  searchInput.addEventListener('input', filterAndSortWork);
  // Initial order enforcement / accessibility
  filterAndSortWork();
</script>

<style>
  .container {
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
    padding: 0.5rem 1rem 1rem 1rem;
  }

  .heading {
    font-size: var(--text-xl);
    margin-bottom: 2rem;
    font-weight: 600;
    text-align: center;
    color: var(--gray-0);
  }

  /* Work Grid Styles */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .work-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2.5rem;
    }
    .heading {
      font-size: var(--text-2xl);
      margin-bottom: 3rem;
    }
    .container {
      padding: 1rem 1rem;
    }
  }

  @media (min-width: 1024px) {
    .work-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
