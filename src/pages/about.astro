---
import Layout from "../layouts/Layout.astro";
import { Image } from 'astro:assets';
import profilePicture from '../assets/me.jpeg';
---

<Layout>
  <article class="about-page">
    <header class="about-hero">
      <Image src={profilePicture} alt="Your photo" class="avatar" />
      <div class="hero-text">
        <h1>Hi, I'm Arthur</h1>
        <p class="lead">I am a software engineer currently pursuing a Master's degree in Computer Science at the University of Bologna, Italy.</p>
        <p class="lead">Born in Brazil and a proud Spanish citizen, I enjoy working in international environments. Beyond tech, my life is all about travel and sports, so there's a good chance you'll catch me out surfing or playing footvolley.</p>
        <p class="lead">I am always eager to connect, collaborate on exciting tech projects, and explore career opportunities.</p>
      </div>
    </header>

    <section>
      <h2>Experience</h2>
      <div class="items">
        <div class="item">
          <p class="period">Dec 2024 - Oct 2025</p>
          <p><strong>Software Engineer Manager</strong> - Cubbo</p>
        </div>
        <div class="item">
          <p class="period">Nov 2022 - Oct 2025</p>
          <p><strong>Full Stack Engineer</strong> - Cubbo</p>
        </div>
        <div class="item">
          <p class="period">Oct 2021 - Feb 2022</p>
          <p><strong>Salesforce B2C Commerce Developer</strong> - Capgemini</p>
        </div>
        <div class="item">
          <p class="period">Sep 2019 - Jul 2020</p>
          <p><strong>Collaborative Scholarship in Information Technology</strong> - University of Barcelona</p>
        </div>
      </div>
    </section>

    <section>
      <h2>Education</h2>
      <div class="items">
        <div class="item">
          <p class="period">2025 - Present</p>
          <p><strong>Master's in Computer Science (Distributed Systems and Networks)</strong> - University of Bologna</p>
        </div>
        <div class="item">
          <p class="period">2018 - 2022</p>
          <p><strong>Bachelor's in Computer Engineering</strong> - University of Barcelona</p>
        </div>
      </div>
    </section>

    <section>
      <h2>Languages</h2>
      <ul>
        <li>Portuguese - Native (C2)</li>
        <li>Spanish - Proficient (C2)</li>
        <li>English — Advanced (C1)</li>
        <li>Catalan — Advanced (C1)</li>
        <li>Italian — Upper-intermediate (B2)</li>
      </ul>
    </section>

    <section>
      <h2>Citizenship</h2>
      <p>Spanish / Brazilian citizen</p>
    </section>

    <section>
      <h2>Hobbies</h2>
      <p>Surfing, footvolley, soccer and traveling</p>
    </section>

    <section>
      <h2>Contact me</h2>
        <p>Email: <a href="mailto:arthurfont2000@gmail.com">arthurfont2000@gmail.com</a></p>
        <p>Phone: <a href="tel:+393520180722">+39 352 018 0722</a></p>      
    </section>
  </article>

  <style>
    .about-page {
      max-width: 900px;
      margin: 2rem auto;
      padding: 0 1rem;
      line-height: 1.6;
    }
    .about-hero {
      display: flex;
      gap: 1rem;
      align-items: stretch;
      margin: 1rem 1rem;
    }
    /* Don't crop the image: keep aspect ratio and show whole image */
    .avatar {
      width: 240px;
      object-fit: contain;
      flex-shrink: 0;
      display: block;
      border-radius: 25px;
    }

    .hero-text {
      background-color: var(--gray-900);
      padding: 2rem 1.5rem;
      border-radius: 25px;
    }

    h1 { 
        margin-bottom: 1rem;
        font-size: var(--text-3xl);
    }

    .period { font-size: var(--text-sm); color: var(--gray-400);} 
    
    .item {
        margin-bottom: 0.5rem;
    }

    .lead { margin: 1rem 0; }

    /* Section spacing */
    section { 
        margin: 0; 
        padding: 2rem; 
        border-radius: 25px;
    }

    section h2 { 
        margin: 0 0 0.5rem 0; 
        font-size: var(--text-2xl);
    }

    ul { margin: 0; padding-left: 1.25rem; }
    li { margin: 2px 0; }

    section:nth-of-type(odd) {
      background: var(--gray-900);
    }

    a { color: var(--link-color); }

    @media (max-width: 640px) {
      .about-hero { flex-direction: column; align-items: flex-start; }
      .avatar { width: 120px; max-height: 160px; }
    }
  </style>
</Layout>
