---
import MainHead from "../components/MainHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import '../styles/global.css';
import FormattedDate from "../components/FormattedDate.astro";
import background from '../assets/background.svg';
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

type Props = {
	work: CollectionEntry<'work'>;
};

const { work } = Astro.props;
const technologies = Object.values(work.data.technologies || {}).flat();
---

<!doctype html>
<html lang="en">
	<head>
		<MainHead />
	</head>
	<body>
		<Header />
		<main class="layout-grid">
			<Image id="background" src={background} alt="" fetchpriority="high" />
			<aside class="metadata">
				<section>
					<h4>Field</h4>
					<div class="field-list">
						{work.data.fields.map(f => <div class="pill-tag">{f}</div>)}
					</div>
				</section>

				<section>
					<h4>Technologies</h4>
					<div class="tech-list">
						{technologies.map(tech => <span class="pill-text">{tech}</span>)}
					</div>
				</section>

				<section>
					<h4>Release Date</h4>
					<FormattedDate date={work.data.date} />
				</section>

				{work.data.link && (
					<section>
						<h4>Link</h4>
						<a href={work.data.link} target="_blank" rel="noopener noreferrer" class="work-link">
							Visit Project
						</a>
					</section>
				)}
			</aside>
			<article class="content">
				<slot />
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.layout-grid {
		margin: 0 auto;
		padding: 1rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		width: 100%;
	}

	.metadata {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.metadata section h4 {
		font-size: var(--text-sm);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--gray-600);
		margin-bottom: 0.75rem;
	}

	.field-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.pill-tag {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		background-color: var(--gray-900);
		color: var(--accent-light);
		border-radius: 999px;
		font-size: var(--text-sm);
		font-weight: 500;
	}

	.tech-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.pill-text {
		font-size: var(--text-sm);
		color: var(--gray-200);
		background-color: var(--gray-800);
		padding: 0.125rem 0.5rem;
		border-radius: 4px;
	}

	.work-link {
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--accent-light);
		text-decoration: underline;
		text-underline-offset: 4px;
	}
	.work-link:hover {
		color: var(--accent-dark);
	}

	.content {
		line-height: 1.7;
	}

	@media (min-width: 640px) {
		.layout-grid {
			grid-template-columns: 200px 1fr;
			gap: 5rem;
            padding: 2rem 1rem;
            max-width: 1200px;
			flex-grow: 1;
		}

		.metadata {
			position: sticky;
			top: 2rem;
			height: fit-content;
			border-bottom: none;
		}
	}
</style>
